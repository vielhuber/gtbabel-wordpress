{
    "scripts": {
        "🔽 js wpbackend (with global transforms) 🔽": "",
        "js:vite:wpbackend": "vite build --logLevel error --mode wpbackend",
        "js:minify:wpbackend": "terser --compress --mangle --output ./assets/build/wpbackend/bundle.js ./assets/build/wpbackend/bundle.js",
        "js:watch:wpbackend": "onchange ./components/*/*.js --initial --poll 50 --delay 0 --await-write-finish 50 -- onerror \"npm run js:vite:wpbackend\" --title \"js:watch:wpbackend\" --message \"build failed\" --sound mute",
        "                                                                                                                                                                                                      ": "",
        "🔽 js wpgutenberg 🔽": "",
        "js:vite:wpgutenberg": "vite build --logLevel error --mode wpgutenberg",
        "js:minify:wpgutenberg": "terser --compress --mangle --output ./assets/build/wpgutenberg/bundle.js ./assets/build/wpgutenberg/bundle.js",
        "js:watch:wpgutenberg": "onchange ./components/*/*.js --initial --poll 50 --delay 0 --await-write-finish 50 -- onerror \"npm run js:vite:wpgutenberg\" --title \"js:watch:wpgutenberg\" --message \"build failed\" --sound mute",
        "                                                                                                                                                                                                       ": "",
        "🔽 css wpbackend 🔽": "",
        "css:sass:wpbackend": "sass --style compressed --no-source-map ./components/wpbackend/style.scss ./assets/build/wpbackend/bundle.css",
        "css:sass:dev:wpbackend": "sass ./components/wpbackend/style.scss ./assets/build/wpbackend/bundle.css",
        "css:postcss:autoprefixer:wpbackend": "postcss --use autoprefixer --output ./assets/build/wpbackend/bundle.css ./assets/build/wpbackend/bundle.css",
        "css:watch:wpbackend": "onchange ./components/*/*.scss --initial --poll 50 --delay 0 --await-write-finish 50 -- onerror \"npm run css:sass:dev:wpbackend\" --title \"css:watch:wpbackend\" --message \"build failed\" --sound mute",
        "                                                                                                                                                                                                        ": "",
        "🔽 css wpgutenberg 🔽": "",
        "css:sass:wpgutenberg": "sass --style compressed --no-source-map ./components/wpgutenberg/style.scss ./assets/build/wpgutenberg/bundle.css",
        "css:sass:dev:wpgutenberg": "sass ./components/wpgutenberg/style.scss ./assets/build/wpgutenberg/bundle.css",
        "css:postcss:autoprefixer:wpgutenberg": "postcss --use autoprefixer --output ./assets/build/wpgutenberg/bundle.css ./assets/build/wpgutenberg/bundle.css",
        "css:watch:wpgutenberg": "onchange ./components/*/*.scss --initial --poll 50 --delay 0 --await-write-finish 50 -- onerror \"npm run css:sass:dev:wpgutenberg\" --title \"css:watch:wpgutenberg\" --message \"build failed\" --sound mute",
        "                                                                                                                                                                                                         ": "",
        "🔽 pipelines 🔽": "",
        "js": "npm-run-all --sequential js:vite:* js:minify:*",
        "js:dev": "npm-run-all --sequential js:vite:*",
        "css": "npm-run-all --sequential css:sass:* css:postcss:autoprefixer:*",
        "css:dev": "npm-run-all --sequential css:sass:dev:*",
        "prod": "npm-run-all --parallel js css",
        "dev": "npm-run-all --parallel js:watch:* css:watch:*"
    },
    "devDependencies": {
        "@prettier/plugin-php": ">=0.25",
        "autoprefixer": "^10.5.0",
        "cli-error-notifier": "^3.0.2",
        "eslint": "^10.4.0",
        "npm-run-all": "^4.1.5",
        "onchange": "^7.1.0",
        "pell": "^1.0.6",
        "postcss-cli": "^11.0.1",
        "prettier": ">=3",
        "sass": "^1.100.0",
        "terser": "^5.48.0",
        "vite": "^8.0.16"
    },
    "overrides": {
        "shell-quote": "^1.8.4",
        "uuid": "^11.1.1"
    },
    "name": "",
    "description": "",
    "version": "0.1.0"
}
